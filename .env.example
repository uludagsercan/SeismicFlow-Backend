# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=change_me

# Keycloak admin console password
KEYCLOAK_ADMIN_PASSWORD=change_me

# seismicflow-admin client secret (generate with: openssl rand -hex 32)
KEYCLOAK_CLIENT_SECRET=change_me

# Tenant DB passwords (add one per tenant)
TENANT_DB_PASSWORD_ACME=change_me
